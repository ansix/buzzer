    "ejs": "^4.0.1",
    "express": "5.0.0",
    "express-session": "^1.19.0",
    "morgan": "~1.9.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "tailwindcss": "^4.2.1"
  }
}
